{
  "name": "txline-sdk",
  "version": "0.1.0",
  "description": "TypeScript/JavaScript SDK for TxLINE Devnet REST, SSE, validation, and Solana instruction builders",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Berektassuly/txline-rs.git",
    "directory": "typescript"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "NOTES.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "keywords": [
    "txline",
    "txodds",
    "solana",
    "sdk"
  ],
  "license": "MIT OR Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@solana/kit": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
